<?xml version="1.0" encoding="utf-8"?>
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="288dp"
            android:height="288dp"
            android:viewportWidth="288"
            android:viewportHeight="288">

            <group
                android:name="logoGroup"
                android:pivotX="144"
                android:pivotY="144"
                android:scaleX="0.6"
                android:scaleY="0.6">

                <!-- Outer Purple Circle -->
                <path
                    android:name="outerCircle"
                    android:fillColor="#8B5CF6"
                    android:fillAlpha="0"
                    android:pathData="M144,32
                                      A112,112 0 1,1 143.9,32 Z"/>

                <!-- Inner White Circle -->
                <path
                    android:name="innerCircle"
                    android:fillColor="#FFFFFF"
                    android:fillAlpha="0"
                    android:pathData="M144,88
                                      A56,56 0 1,1 143.9,88 Z"/>

                <!-- Play Icon -->
                <path
                    android:name="playIcon"
                    android:fillColor="#8B5CF6"
                    android:fillAlpha="0"
                    android:pathData="M128,112 L128,176 L184,144 Z"/>

            </group>
        </vector>
    </aapt:attr>

    <!-- Scale X -->
    <target android:name="logoGroup">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="scaleX"
                android:valueFrom="0.6"
                android:valueTo="1"
                android:duration="600"
                android:valueType="floatType"
                android:interpolator="@android:anim/overshoot_interpolator"/>
        </aapt:attr>
    </target>

    <!-- Scale Y -->
    <target android:name="logoGroup">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="scaleY"
                android:valueFrom="0.6"
                android:valueTo="1"
                android:duration="600"
                android:valueType="floatType"
                android:interpolator="@android:anim/overshoot_interpolator"/>
        </aapt:attr>
    </target>

    <!-- Outer Circle Fade -->
    <target android:name="outerCircle">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="300"
                android:valueType="floatType"/>
        </aapt:attr>
    </target>

    <!-- Inner Circle Fade -->
    <target android:name="innerCircle">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:startOffset="150"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="300"
                android:valueType="floatType"/>
        </aapt:attr>
    </target>

    <!-- Play Icon Fade -->
    <target android:name="playIcon">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:startOffset="300"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="250"
                android:valueType="floatType"/>
        </aapt:attr>
    </target>

</animated-vector>